        "/api/cart/merge": {
            "post": {
                "tags": [
                    "Carrito"
                ],
                "summary": "Sincronizar carrito",
                "operationId": "f97547c1a24efa42a3eed9c97f283ea6",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "cart"
                                ],
                                "properties": {
                                    "cart": {
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "properties": {
                                                        "product_id": {
                                                            "type": "integer"
                                                        },
                                                        "quantity": {
                                                            "type": "integer"
                                                        },
                                                        "price": {
                                                            "type": "number",
                                                            "format": "float"
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            }
                                        },
                                        "type": "object"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sincronizado"
                    },
                    "400": {
                        "description": "Datos inválidos"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
