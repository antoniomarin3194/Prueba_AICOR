{
    "openapi": "3.0.0",
    "info": {
        "title": "Aicor API",
        "description": "Documentación de endpoints de autenticación, productos, carrito, órdenes y administración.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "{scheme}://{host}",
            "variables": {
                "scheme": {
                    "enum": [
                        "http",
                        "https"
                    ],
                    "default": "http"
                },
                "host": {
                    "default": "localhost:8000"
                }
            }
        }
    ],
    "paths": {
        "/api/auth/google/redirect": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Redirige a Google OAuth",
                "operationId": "da6513ff89233b7635b80d661a5f2425",
                "responses": {
                    "302": {
                        "description": "Redirección"
                    }
                }
            }
        },
        "/api/auth/google/callback": {
            "get": {
                "tags": [
                    "Auth"
                ],
                "summary": "Callback Google",
                "operationId": "b17960bf11ba1ba7ea4664358db5f157",
                "responses": {
                    "302": {
                        "description": "Redirección al frontend con token"
                    }
                }
            }
        },
        "/api/products": {
            "get": {
                "tags": [
                    "Productos"
                ],
                "summary": "Lista productos",
                "operationId": "708e29992c114c195ce7f8ce92d2de10",
                "responses": {
                    "200": {
                        "description": "Lista de productos",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/admin/login": {
            "post": {
                "tags": [
                    "Admin"
                ],
                "summary": "Login admin",
                "operationId": "bc85b2d3028f8c379723ef3810717cae",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "admin@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login correcto"
                    },
                    "401": {
                        "description": "Credenciales inválidas"
                    },
                    "403": {
                        "description": "Sin permisos admin"
                    }
                }
            }
        },
        "/api/admin/logout": {
            "post": {
                "tags": [
                    "Admin"
                ],
                "summary": "Logout admin",
                "operationId": "e4a31bf90ca09bafb4b2b3297fc45f43",
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "401": {
                        "description": "No autenticado"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/me": {
            "get": {
                "tags": [
                    "Admin"
                ],
                "summary": "Admin autenticado",
                "operationId": "bedacb98f4413e0a6a115cdd423a9b64",
                "responses": {
                    "200": {
                        "description": "Usuario actual"
                    },
                    "401": {
                        "description": "No autenticado"
                    },
                    "403": {
                        "description": "Sin permisos admin"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/products": {
            "post": {
                "tags": [
                    "Admin"
                ],
                "summary": "Crear producto",
                "operationId": "580395f9d6502c6d0886e37886ca9e8b",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "price",
                                    "stock"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string"
                                    },
                                    "description": {
                                        "type": "string",
                                        "nullable": true
                                    },
                                    "price": {
                                        "type": "number",
                                        "format": "float"
                                    },
                                    "stock": {
                                        "type": "integer"
                                    },
                                    "image_url": {
                                        "type": "string",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Creado"
                    },
                    "422": {
                        "description": "Validación"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/admin/products/{product}": {
            "put": {
                "tags": [
