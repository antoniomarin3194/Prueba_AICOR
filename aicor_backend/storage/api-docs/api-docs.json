        "/api/admin/orders/{order}/status": {
            "put": {
                "tags": [
                    "Admin"
                ],
                "summary": "Actualizar estado de orden",
                "operationId": "405a09788565a8eb6c9a393af6ee7af1",
                "parameters": [
                    {
                        "name": "order",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
